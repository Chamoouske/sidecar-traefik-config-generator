{
    "name": "sidecar-traefik-federation",
    "version": "1.0.0",
    "description": "Gera configuração dinâmica do Traefik baseada em nós Docker Swarm elegíveis",
    "type": "module",
    "main": "dist/index.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/index.js",
        "dev": "tsx src/index.ts",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "keywords": [
        "traefik",
        "docker",
        "swarm",
        "federation"
    ],
    "license": "MIT",
    "dependencies": {
        "dockerode": "^4.0.0",
        "js-yaml": "^4.1.1",
        "pino": "^9.0.0",
        "pino-pretty": "^13.0.0"
    },
    "devDependencies": {
        "@types/dockerode": "^4.0.0",
        "@types/js-yaml": "^4.0.9",
        "@types/node": "^22.0.0",
        "tsx": "^4.0.0",
        "typescript": "^5.5.0",
        "vitest": "^3.1.1"
    }
}
